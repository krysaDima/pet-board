# Скопируйте в `.env` для локальной разработки.
#
# API бэкенда: только origin, без пути /api/v1 (его дописывает клиент).
# Неправильно: http://localhost:8080/api/v1
# Правильно:  http://localhost:8080
# Не оставляйте ключ пустым (`VITE_API_URL=`): относительные ссылки медиа должны склеиваться с этим host.
#
# GitHub Actions: задайте repository variable VITE_API_URL (HTTPS URL вашего API).
#
VITE_USE_MOCKS=false
VITE_API_URL=http://localhost:8080
