# Скопируйте в `.env` для локальной разработки.
#
# API бэкенда: только origin, без пути /api/v1 (его дописывает клиент).
# Неправильно: http://localhost:8080/api/v1
# Правильно:  http://localhost:8080
#
# Локально: VITE_API_URL как выше.
#
# VPS (nginx отдаёт фронт и проксирует /api → Spring на localhost:8080):
#   уберите VITE_API_URL из .env или оставьте пустым, base фронта «/»: npm run build:vps
#   Пример см. deploy/nginx-vps.conf.example в этом репозитории.
#
# GitHub Pages: задайте VITE_API_URL в CI (variable/secret) — публичный HTTPS URL API.
#
VITE_USE_MOCKS=false
VITE_API_URL=http://localhost:8080
